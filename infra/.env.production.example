# Copy to .env.production next to docker-compose.prod.yml and fill in values.
# docker compose -f docker-compose.prod.yml --env-file .env.production ...

# --- Public URLs (no trailing slash) ---
PUBLIC_BASE_URL=https://repairs.example.ch
CORS_ORIGIN=https://repairs.example.ch

# Hostname for Caddy (TLS). Must point DNS A/AAAA to this server before first start.
SERVER_NAME=repairs.example.ch

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-long-random-password
POSTGRES_DB=repair_platform

# API: use the docker service name `postgres` as host
DATABASE_URL=postgresql://postgres:change-me-to-a-long-random-password@postgres:5432/repair_platform

# --- API secrets ---
JWT_SECRET=change-me-to-a-long-random-secret

# Optional: session length (default 30d)
# JWT_EXPIRES_IN=30d

# --- Optional SMTP (password reset emails) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.ch

# --- Optional: printing on the server (usually unused when using print agents) ---
# DEFAULT_PRINTER_MODE=spool
# PHOTO_STORAGE_DIR=/app/storage/photos
